# Harness durable layer — each project instance generates its own data.
harness.db
harness.db-wal
harness.db-shm

# Rust build output for harness tooling.
target/
dist/

# Downloaded Harness CLI binary for installed project instances.
scripts/bin/harness-cli
scripts/bin/harness-cli.exe

# Local implementation worktrees.
.worktrees/

# Local Superpowers brainstorming/runtime state.
.superpowers/

# Node/Next.js application dependencies and build output.
node_modules/
apps/*/node_modules/
apps/*/.next/
apps/*/out/
apps/*/coverage/
apps/*/test-results/
apps/*/playwright-report/

# Local environment files.
.env*
apps/*/.env*
!.env.example
!apps/*/.env.example
